<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{B90F1FD4-5E6E-4F26-9B93-9C0FD32929C5}</ProjectGuid>
    <RootNamespace>WindowsVhidStack</RootNamespace>
    <WindowsTargetPlatformVersion>10.0.28000.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <DriverTargetPlatform>Universal</DriverTargetPlatform>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <VhidWdkRoot Condition="'$(WDKContentRoot)' != ''">$(WDKContentRoot)</VhidWdkRoot>
    <VhidWdkRoot Condition="'$(VhidWdkRoot)' == '' and '$(WindowsSdkDir)' != ''">$(WindowsSdkDir)</VhidWdkRoot>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(VhidWdkRoot)' != ''">
    <ClCompile>
      <AdditionalIncludeDirectories>$(VhidWdkRoot)Include\$(WindowsTargetPlatformVersion)\km;$(VhidWdkRoot)Include\$(WindowsTargetPlatformVersion)\shared;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <AdditionalDependencies>VhfKm.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(VhidWdkRoot)Lib\$(WindowsTargetPlatformVersion)\km\$(Platform);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <SignMode>Off</SignMode>
    <Inf2CatWindowsVersionList>10_X64</Inf2CatWindowsVersionList>
  </PropertyGroup>
  <ItemGroup>
    <ClInclude Include="Device.h" />
    <ClInclude Include="Driver.h" />
    <ClInclude Include="Trace.h" />
    <ClInclude Include="VhfDevice.h" />
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="Device.c" />
    <ClCompile Include="Driver.c" />
    <ClCompile Include="VhfDevice.c" />
  </ItemGroup>
  <ItemGroup>
    <Inf Include="VirtualInput.inf" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <!-- Stage the freshly linked .sys into the package folder that Inf2Cat scans
       so the catalog signability test can resolve it (fixes Inf2Cat error
       22.9.1). The scan folder is $(OutDir)$(ProjectName)\ per the T-016 build
       evidence ("VirtualInput\virtualinput.inf"). AfterTargets=Link guarantees
       the copy runs even if the Inf2Cat target name differs by WDK version. -->
  <Target Name="StageSysForInf2Cat" AfterTargets="Link" BeforeTargets="Inf2Cat">
    <Copy SourceFiles="$(TargetPath)"
          DestinationFolder="$(OutDir)$(ProjectName)\"
          SkipUnchangedFiles="false" />
  </Target>
</Project>
